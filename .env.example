# Copier vers .env et renseigner les valeurs du tableau Supabase : Paramètres du projet → API
# URL du projet (https://xxx.supabase.co)

EXPO_PUBLIC_SUPABASE_URL=https://votre-ref.supabase.co

# Clé « anon » (JWT) ou clé publishable (sb_publishable_...) — les deux conviennent côté client

EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_cle_publique

# Google Cloud : activer « Places API (New) » + « Routes API » + facturation.
# Restreindre la clé (bundle iOS, etc.). Même clé pour Places et Routes.
# https://console.cloud.google.com/google/maps-apis

EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Stripe (Payment Sheet côté app — clé publishable uniquement ; secret sur Edge Functions)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Edge Functions : STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, SUPABASE_SERVICE_ROLE_KEY (dashboard Supabase)
#
# Expiration paiement (5 min) : create-payment-intent appelle aussi expire_rides_past_payment_deadline.
# Pour expirer sans action client, planifier en base (ex. pg_cron) : SELECT public.expire_rides_past_payment_deadline();


